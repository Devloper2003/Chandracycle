# ═══════════════════════════════════════════════════════════════════════════
# ChandraCycle — Environment Variables Template
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# For Vercel deployment, set each variable in:
#   Vercel → Project → Settings → Environment Variables
# (Apply each to Production, Preview, AND Development environments)
# ═══════════════════════════════════════════════════════════════════════════

# ─── JWT Secret (REQUIRED) ──────────────────────────────────────────────────
# Generate one with: openssl rand -base64 48
# Used to sign session tokens. MUST be set in production.
JWT_SECRET=

# ─── Google OAuth (REQUIRED for Google login) ───────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# We use Google Identity Services (GIS) — only the Client ID is needed (no secret).
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ─── PayPal (REQUIRED for premium subscriptions) ────────────────────────────
# From PayPal Developer Dashboard → My Apps & Credentials
# PAYPAL_MODE: "sandbox" for testing, "live" for real payments
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# ─── Apple Sign-In (optional — modal fallback works without this) ──────────
APPLE_CLIENT_ID=com.chandracycle.app
NEXT_PUBLIC_APPLE_CLIENT_ID=com.chandracycle.app

# ─── Database ───────────────────────────────────────────────────────────────
# Local dev: SQLite file. Vercel: ephemeral (auth works via JWT fallback).
# For full data persistence, migrate to Turso (free tier):
#   DATABASE_URL=libsql://your-db.turso.io
#   see https://turso.tech for setup
DATABASE_URL=file:./prisma/dev.db
