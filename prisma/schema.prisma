generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════════════════
// UNIFIED SCHEMA — shared by both ChandraCycle (main app) and ChandraCycle-admin
// Both apps connect to the same Neon PostgreSQL database.
// ═══════════════════════════════════════════════════════════════════════════

// ---- End users (registered on main website, managed by admin) ----
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  avatar       String?
  password     String?       // auth password (used by main website)
  phone        String?
  provider     String   @default("email")  // email | google | apple (auth provider)
  dateOfBirth  String?
  height       Float?
  weight       Float?
  cycleLength  Int      @default(28)
  periodLength Int      @default(5)
  lastPeriodStart String?
  onboardingComplete Boolean @default(false)

  // Location
  city         String?
  country      String?

  // Account control (admin)
  accountStatus String  @default("active") // active | suspended | banned | pending
  banReason     String?
  notes         String?
  flagged       Boolean @default(false)
  emailVerified Boolean @default(false)
  lastLoginAt   DateTime?

  // Subscription / billing
  subscriptionTier    String?  // free | premium | plus
  subscriptionStatus  String?  // active | cancelled | expired | trialing | suspended
  subscriptionPlan    String?  // monthly | yearly
  subscriptionStart   DateTime?
  subscriptionEnd     DateTime?
  trialStartDate      DateTime?
  trialEndDate        DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations from main website
  cycles       Cycle[]
  symptoms     SymptomEntry[]
  moodEntries  MoodEntry[]
  sleepEntries SleepEntry[]
  waterEntries WaterEntry[]
  pcosRecords  PCOSRecord[]
  fertilityData FertilityData[]
  pregnancyData PregnancyData[]
  menopauseData MenopauseData[]
  chatMessages ChatMessage[]
  communityPosts CommunityPost[]
  comments     Comment[]
  appointments Appointment[]
  reports      Report[]
  notifications Notification[]
  // Relations from admin
  subscriptions Subscription[]
  authSessions  AuthSession[]
}

// ---- Admin (operator) accounts ----
model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("admin") // super_admin | admin | moderator
  avatar       String?
  lastLoginAt  DateTime?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditLogs AuditLog[]
  sessions AdminSession[]
}

// ---- Admin login sessions (DB-backed) ----
model AdminSession {
  id        String   @id @default(cuid())
  token     String   @unique
  adminId   String
  createdAt DateTime @default(now())
  expiresAt DateTime
  revoked   Boolean  @default(false)
  ipAddress String?

  admin AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
}

// ---- End user auth sessions ----
model AuthSession {
  id          String   @id @default(cuid())
  userId      String
  token       String   @unique
  deviceInfo  String?
  ipAddress   String?
  location    String?
  createdAt   DateTime @default(now())
  expiresAt   DateTime
  revoked     Boolean  @default(false)
  revokedAt   DateTime?
  revokedReason String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---- Subscription / payment records ----
model Subscription {
  id            String   @id @default(cuid())
  userId        String
  plan          String   // monthly | yearly
  tier          String   @default("premium") // basic | premium
  amount        Float
  gst           Float
  total         Float
  currency      String   @default("INR")
  status        String   @default("active") // active | cancelled | expired | refunded | suspended
  startDate     DateTime @default(now())
  endDate       DateTime
  paymentMethod String?
  transactionId String?
  invoiceId     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---- Site settings / feature flags (key-value) ----
model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

// ---- Broadcast announcements ----
model Announcement {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   @default("info") // info | warning | success | maintenance
  audience  String   @default("all") // all | free | premium
  active    Boolean  @default(true)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---- Audit trail of admin actions ----
model AuditLog {
  id         String   @id @default(cuid())
  adminId    String?
  adminName  String?
  action     String
  targetType String?
  targetId   String?
  targetLabel String?
  details    String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  admin AdminUser? @relation(fields: [adminId], references: [id], onDelete: SetNull)
}

// ---- Marketing campaigns & ads ----
model Campaign {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("banner")
  title       String
  message     String
  ctaText     String?
  ctaLink     String?
  imageUrl    String?
  position    String   @default("top")
  audience    String   @default("all")
  status      String   @default("draft")
  startDate   DateTime?
  endDate     DateTime?
  budget      Float?
  spent       Float    @default(0)
  impressions Int      @default(0)
  clicks      Int      @default(0)
  conversions Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ---- Backup & restore logs ----
model BackupLog {
  id          String   @id @default(cuid())
  type        String
  status      String
  filename    String?
  fileSize    Int?
  tableCount  Int?
  recordCount Int?
  triggeredBy String?
  adminId     String?
  message     String?
  createdAt   DateTime @default(now())
}

// ---- Payment gateway configuration ----
model PaymentConfig {
  id              String   @id @default(cuid())
  gateway         String   @default("razorpay")
  displayName     String   @default("Razorpay")
  apiKey          String?
  apiSecret       String?
  merchantId      String?
  webhookSecret   String?
  webhookUrl      String?
  paymentLinkUrl  String?
  successUrl      String?
  failureUrl      String?
  mode            String   @default("test")
  active          Boolean  @default(true)
  currency        String   @default("INR")
  supportedMethods String?
  lastSyncedAt    DateTime?
  lastSyncStatus  String?
  lastSyncMessage String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ---- Payment transactions (synced from main app) ----
model PaymentTransaction {
  id              String   @id @default(cuid())
  txnId           String?
  orderId         String?
  userId          String?
  userEmail       String?
  userName        String?
  amount          Float
  currency        String   @default("INR")
  status          String   @default("created")
  method          String?
  gateway         String?
  description     String?
  errorMsg        String?
  syncedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════════════════════
// Main website health-tracking models
// ═══════════════════════════════════════════════════════════════════════════

model Cycle {
  id          String   @id @default(cuid())
  userId      String
  startDate   String
  endDate     String?
  cycleLength Int?
  periodLength Int?
  ovulationDate String?
  fertilityWindowStart String?
  fertilityWindowEnd String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model SymptomEntry {
  id        String   @id @default(cuid())
  userId    String
  date      String
  category  String
  severity  Int      @default(1)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([date])
}

model MoodEntry {
  id        String   @id @default(cuid())
  userId    String
  date      String
  mood      String
  energy    Int      @default(3)
  stress    Int      @default(3)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([date])
}

model SleepEntry {
  id          String   @id @default(cuid())
  userId      String
  date        String
  hoursSlept  Float
  quality     Int      @default(3)
  bedTime     String?
  wakeTime    String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([date])
}

model WaterEntry {
  id        String   @id @default(cuid())
  userId    String
  date      String
  glasses   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([date])
}

model PCOSRecord {
  id              String   @id @default(cuid())
  userId          String
  date            String
  irregularPeriods Boolean @default(false)
  excessHair      Boolean @default(false)
  acne            Boolean @default(false)
  weightGain      Boolean @default(false)
  hairLoss        Boolean @default(false)
  skinTags        Boolean @default(false)
  fatigue         Boolean @default(false)
  moodChanges     Boolean @default(false)
  sleepIssues     Boolean @default(false)
  riskScore       Float?
  exerciseMinutes Int     @default(0)
  dietQuality     Int     @default(3)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model FertilityData {
  id                  String   @id @default(cuid())
  userId              String
  date                String
  basalTemp           Float?
  cervicalMucus       String?
  opkResult           String?
  fertilityScore      Float?
  ovulationConfirmed  Boolean  @default(false)
  intercourse         Boolean  @default(false)
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model PregnancyData {
  id              String   @id @default(cuid())
  userId          String
  date            String
  week            Int
  day             Int      @default(0)
  weight          Float?
  bloodPressure   String?
  babySize        String?
  symptoms        String?
  mood            String?
  appointmentDue  String?
  vaccinationDue  String?
  medicineTaken   String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model MenopauseData {
  id              String   @id @default(cuid())
  userId          String
  date            String
  hotFlashes      Int      @default(0)
  nightSweats     Int      @default(0)
  moodChanges     Boolean  @default(false)
  sleepIssues     Boolean  @default(false)
  vaginalDryness  Boolean  @default(false)
  jointPain       Boolean  @default(false)
  weightChange    Float?
  anxiety         Int      @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model CommunityPost {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String
  category  String
  isAnonymous Boolean @default(true)
  likes     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments Comment[]
  @@index([userId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String
  isAnonymous Boolean @default(true)
  createdAt DateTime @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([postId])
}

model Appointment {
  id          String   @id @default(cuid())
  userId      String
  doctorName  String
  specialty   String
  date        String
  time        String
  type        String
  status      String   @default("upcoming")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model Report {
  id          String   @id @default(cuid())
  userId      String
  type        String
  startDate   String
  endDate     String
  content     String
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([read])
}
